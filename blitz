#!/usr/bin/env python3
"""
Blitz CLI - Main entry point for blitz commands
Usage: blitz [config|status|version]
"""

import sys
import json
from pathlib import Path
from datetime import datetime, timezone

# Colors
class Colors:
    GOLD = "\033[38;5;220m"
    CYAN = "\033[38;5;51m"
    GREEN = "\033[38;5;82m"
    YELLOW = "\033[38;5;227m"
    RED = "\033[38;5;196m"
    MAGENTA = "\033[38;5;201m"
    BOLD = "\033[1m"
    DIM = "\033[2m"
    RESET = "\033[0m"

def get_blitz_home() -> Path:
    """Get Blitz home directory"""
    return Path.home() / ".blitz"

def get_prefs_file() -> Path:
    """Get preferences file path"""
    return get_blitz_home() / "preferences.json"

def load_preferences() -> dict:
    """Load user preferences"""
    prefs_file = get_prefs_file()
    if not prefs_file.exists():
        return {
            "tone": "sassy",
            "trust_mode": "notify",
            "onboarded": False,
            "version": "3.1"
        }
    try:
        return json.loads(prefs_file.read_text())
    except:
        return {}

def save_preferences(prefs: dict):
    """Save user preferences"""
    get_blitz_home().mkdir(parents=True, exist_ok=True)
    prefs["updated_at"] = datetime.now(timezone.utc).isoformat()
    get_prefs_file().write_text(json.dumps(prefs, indent=2))

def print_banner():
    """Print Blitz banner"""
    banner = f"""{Colors.GOLD}{Colors.BOLD}
╔══════════════════════════════════════════════════════════════╗
║  ⚡️ BLITZ v3.1                                                ║
║  {Colors.DIM}The development autopilot{Colors.GOLD}{' ' * 40}║
╚══════════════════════════════════════════════════════════════╝{Colors.RESET}
"""
    print(banner)

def show_status():
    """Show current Blitz status"""
    print_banner()
    prefs = load_preferences()
    
    print(f"{Colors.CYAN}◆ Current Configuration{Colors.RESET}\n")
    
    tone = prefs.get("tone", "sassy").capitalize()
    trust = prefs.get("trust_mode", "notify").capitalize()
    onboarded = prefs.get("onboarded", False)
    
    print(f"  {Colors.GREEN}●{Colors.RESET} Tone:        {Colors.BOLD}{tone}{Colors.RESET}")
    print(f"  {Colors.GREEN}●{Colors.RESET} Trust Mode:  {Colors.BOLD}{trust}{Colors.RESET}")
    print(f"  {Colors.GREEN}●{Colors.RESET} Status:      {'Ready to build' if onboarded else 'Not configured'}")
    print(f"  {Colors.DIM}●{Colors.RESET} Config:      {get_prefs_file()}")
    print()
    
    # Show unlock progress
    history_file = get_blitz_home() / "history.json"
    project_count = 0
    if history_file.exists():
        try:
            history = json.loads(history_file.read_text())
            project_count = len([p for p in history.get("projects", []) if p.get("completed")])
        except:
            pass
    
    print(f"{Colors.CYAN}◆ Progress{Colors.RESET}\n")
    print(f"  Projects completed: {Colors.BOLD}{project_count}{Colors.RESET}")
    
    if project_count < 3:
        remaining = 3 - project_count
        print(f"  {Colors.YELLOW}⚡ Auto Mode unlocks in {remaining} project{'s' if remaining > 1 else ''}{Colors.RESET}")
    elif project_count < 10:
        remaining = 10 - project_count
        print(f"  {Colors.YELLOW}⚡ Ghost Mode unlocks in {remaining} project{'s' if remaining > 1 else ''}{Colors.RESET}")
    else:
        print(f"  {Colors.GREEN}✓ All modes unlocked!{Colors.RESET}")
    print()

def get_blitz_install_dir() -> Path:
    """Find the Blitz installation directory"""
    # First check if we're running from the symlink
    script_path = Path(__file__)
    if script_path.is_symlink():
        script_path = script_path.resolve()
    
    # Try the script's directory first
    if (script_path.parent / "setup.py").exists():
        return script_path.parent
    
    # Fallback to standard install location
    std_path = Path.home() / ".claude" / "skills" / "blitz-v3"
    if (std_path / "setup.py").exists():
        return std_path
    
    # Last resort - try blitz symlink
    alt_path = Path.home() / ".claude" / "skills" / "blitz"
    if (alt_path / "setup.py").exists():
        return alt_path
    
    return script_path.parent

def run_config_wizard():
    """Run the configuration wizard"""
    import importlib.util
    
    blitz_dir = get_blitz_install_dir()
    setup_path = blitz_dir / "setup.py"
    
    if setup_path.exists():
        spec = importlib.util.spec_from_file_location("setup", setup_path)
        setup_module = importlib.util.module_from_spec(spec)
        spec.loader.exec_module(setup_module)
        setup_module.run_setup()
    else:
        print(f"{Colors.RED}Error: setup.py not found at {setup_path}{Colors.RESET}")
        print(f"{Colors.DIM}Try reinstalling: ./install.sh{Colors.RESET}")
        sys.exit(1)

def show_help():
    """Show help message"""
    print_banner()
    print(f"{Colors.CYAN}◆ Commands{Colors.RESET}\n")
    print(f"  {Colors.BOLD}blitz{Colors.RESET}           Show status")
    print(f"  {Colors.BOLD}blitz config{Colors.RESET}    Re-run configuration wizard")
    print(f"  {Colors.BOLD}blitz status{Colors.RESET}    Show current configuration")
    print(f"  {Colors.BOLD}blitz version{Colors.RESET}   Show version info")
    print(f"  {Colors.BOLD}blitz --help{Colors.RESET}    Show this help message")
    print()
    print(f"{Colors.DIM}More info: https://github.com/sprajapati024/blitz{Colors.RESET}")
    print()

def main():
    """Main entry point"""
    args = sys.argv[1:]
    
    if not args or args[0] in ("status", "st"):
        show_status()
    elif args[0] in ("config", "configure", "setup"):
        run_config_wizard()
    elif args[0] in ("--help", "-h", "help"):
        show_help()
    elif args[0] in ("--version", "-v", "version"):
        print(f"Blitz v3.1")
    else:
        print(f"{Colors.RED}Unknown command: {args[0]}{Colors.RESET}")
        print(f"Run {Colors.BOLD}blitz --help{Colors.RESET} for usage")
        sys.exit(1)

if __name__ == "__main__":
    main()
